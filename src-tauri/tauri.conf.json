{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iplayer",
  "version": "0.1.0",
  "identifier": "com.iplayer.app",
  "build": {
    "frontendDist": "../src-ui",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "iplayer",
        "width": 860,
        "height": 580,
        "minWidth": 860,
        "minHeight": 580,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
